<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SVG Drawer with Undo/Redo + Reset</title>
<style>
  body { font-family: sans-serif; }
  #coords {
    position: absolute;
    top: -3px;
    left: -1px;
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 1px 1px;
    border-radius: 4px;
    font-size: 12px;
  }
  svg { border: 1px solid #ccc; }
  circle.point { fill: black; stroke: black; stroke-width: 1px; }
  circle.ctrl { fill: limegreen; stroke: black; stroke-width: 1px; }
  #commandsLog { margin-top: 10px; font-family: monospace; color: green; }
  input {width: 50px;}
  select {width: 60px;}
</style>
</head>
<body>

<div id="coords">X:0 Y:0</div>

<svg id="canvas" width="650" height="550">
  <path id="path" d="" stroke="black" fill="none" stroke-width="1"></path>
  <circle id="point" class="point" cx="0" cy="0" r="1" visibility="hidden"></circle>
  <circle id="ctrlPoint" class="ctrl" cx="0" cy="0" r="1" visibility="hidden"></circle>
  <circle id="ctrlPoint2" class="ctrl" cx="0" cy="0" r="1" visibility="hidden"></circle>
</svg>

<div>
  <label>Command:
    <select id="command">
      <option value="M">Move</option>
      <option value="L">Line</option>
      <option value="A">Arc</option>
      <option value="Q">Quadratic</option>
      <option value="C">Cubic</option>
    </select>
  </label>
  <label>X: <input type="number" id="x" value="100"></label>
  <label>Y: <input type="number" id="y" value="100"></label>
  <label>CtrlX: <input type="number" id="cx" value="150"></label>
  <label>CtrlY: <input type="number" id="cy" value="50"></label>
  <label>CtrlX2: <input type="number" id="cx2" value="200"></label>
  <label>CtrlY2: <input type="number" id="cy2" value="150"></label>
  <button id="draw">Draw</button>
  <button id="reset">Reset</button>
</div>

<div id="commandsLog">Commands: </div>

<script>
const pathEl = document.getElementById('path');
const pointEl = document.getElementById('point');
const ctrlEl = document.getElementById('ctrlPoint');
const ctrlEl2 = document.getElementById('ctrlPoint2');
const commandsLogEl = document.getElementById('commandsLog');
const svg = document.getElementById('canvas');
const drawBtn = document.getElementById('draw');
const resetBtn = document.getElementById('reset');

let commandsArray = [];
let redoStack = [];

// Load saved commands from localStorage
const saved = localStorage.getItem("svgCommands");
if (saved) {
  commandsArray = JSON.parse(saved);
  updatePath();
}

function updatePath() {
  const d = commandsArray.join(" ");
  pathEl.setAttribute("d", d);
  commandsLogEl.textContent = "Commands: " + d;
  localStorage.setItem("svgCommands", JSON.stringify(commandsArray));
}

function drawCommand() {
  const cmd = document.getElementById('command').value;
  const x = document.getElementById('x').value;
  const y = document.getElementById('y').value;

  if (cmd === "M") {
    commandsArray.push(`M${x},${y}`);
  } else if (cmd === "L") {
    commandsArray.push(`L${x},${y}`);
  } else if (cmd === "A") {
    commandsArray.push(`A50,50 0 0,1 ${x},${y}`);
  } else if (cmd === "Q") {
    const cx = document.getElementById('cx').value;
    const cy = document.getElementById('cy').value;
    commandsArray.push(`Q${cx},${cy} ${x},${y}`);
    ctrlEl.setAttribute("cx", cx);
    ctrlEl.setAttribute("cy", cy);
    ctrlEl.setAttribute("visibility", "visible");
    ctrlEl2.setAttribute("visibility", "hidden");
  } else if (cmd === "C") {
    const cx = document.getElementById('cx').value;
    const cy = document.getElementById('cy').value;
    const cx2 = document.getElementById('cx2').value;
    const cy2 = document.getElementById('cy2').value;
    commandsArray.push(`C${cx},${cy} ${cx2},${cy2} ${x},${y}`);
    ctrlEl.setAttribute("cx", cx);
    ctrlEl.setAttribute("cy", cy);
    ctrlEl.setAttribute("visibility", "visible");
    ctrlEl2.setAttribute("cx", cx2);
    ctrlEl2.setAttribute("cy", cy2);
    ctrlEl2.setAttribute("visibility", "visible");
  }

  redoStack = []; // clear redo stack after new draw
  updatePath();

  pointEl.setAttribute("cx", x);
  pointEl.setAttribute("cy", y);
  pointEl.setAttribute("visibility", "visible");
}

drawBtn.addEventListener('click', drawCommand);

// Global keyboard handler
document.addEventListener('keydown', (e) => {
  const key = e.key.toLowerCase();
  if (e.ctrlKey && key === 'z') {
    e.preventDefault();
    if (commandsArray.length > 0) {
      const undone = commandsArray.pop();
      redoStack.push(undone);
      updatePath();
    }
  }
  if (e.ctrlKey && key === 'y') {
    e.preventDefault();
    if (redoStack.length > 0) {
      const redone = redoStack.pop();
      commandsArray.push(redone);
      updatePath();
    }
  }
  if (key === 'enter') {
    e.preventDefault();
    drawCommand();
  }
});

// Reset button clears everything but allows Redo
resetBtn.addEventListener('click', () => {
  if (commandsArray.length > 0) {
    // Save current full path as one redo-able state
    redoStack.push(commandsArray.join(" "));
  }
  commandsArray = [];
  pathEl.setAttribute("d", "");
  commandsLogEl.textContent = "Commands: ";
  pointEl.setAttribute("visibility", "hidden");
  ctrlEl.setAttribute("visibility", "hidden");
  ctrlEl2.setAttribute("visibility", "hidden");
  localStorage.removeItem("svgCommands");
});

// Coordinates display
const coordsEl = document.getElementById('coords');
svg.addEventListener('mousemove', (e) => {
  const rect = svg.getBoundingClientRect();
  const x = Math.round(e.clientX - rect.left);
  const y = Math.round(e.clientY - rect.top);
  coordsEl.textContent = `X:${x} Y:${y}`;
});
</script>

</body>
</html>
